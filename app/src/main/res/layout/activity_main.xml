<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <!-- Content: full-screen gauge + floating controls overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <com.rogerneumann.autovakt.ui.DashboardView
            android:id="@+id/dashboardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Dim scrim for pre-connection / not-configured state (11d) -->
        <View
            android:id="@+id/viewDimScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:visibility="gone" />

        <!-- Hamburger button — alpha=0 by default, fades in on gauge tap -->
        <ImageButton
            android:id="@+id/btnHamburger"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_menu_24"
            android:contentDescription="Open menu"
            android:alpha="0"
            android:padding="8dp" />

        <!-- Trip history FAB — bottom-right, 1-tap access to current trip + history -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabTrips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="36dp"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_history_24"
            android:contentDescription="Trip History"
            app:backgroundTint="#CC1C1C1E"
            app:tint="#00E676"
            app:fabSize="mini"
            app:elevation="4dp" />

        <!-- DEMO badge — shown only in demo mode -->
        <TextView
            android:id="@+id/tvDemoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:text="DEMO"
            android:textColor="#FF6D00"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#33FF6D00"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#121212"
        android:fitsSystemWindows="true"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/nav_header_main"
        app:itemTextColor="@color/nav_item_text"
        app:itemIconTint="#00E676" />

</androidx.drawerlayout.widget.DrawerLayout>
