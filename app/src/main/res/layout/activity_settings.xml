<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- Vehicle Profile -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Vehicle Profile"
            android:textColor="#B0BEC5"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerVehicle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="32dp" />

        <!-- Unit System -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unit System"
            android:textColor="#B0BEC5"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radioGroupUnits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <RadioButton
                android:id="@+id/radioImperial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imperial (mph, mi/kWh)"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="16dp" />

            <RadioButton
                android:id="@+id/radioMetric"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metric (km/h, Wh/km)"
                android:textColor="#FFFFFF" />
        </RadioGroup>

        <!-- ── Dashboard Layout ───────────────────────────────────────────── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Dashboard Layout" android:textColor="#B0BEC5"
            android:layout_marginBottom="12dp" />

        <RadioGroup android:id="@+id/radioGroupLayout"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="8dp">
            <RadioButton android:id="@+id/radioLayout2" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="2 Slots (1×2)"
                android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/radioLayout4" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="4 Slots (2×2)"
                android:textColor="#FFFFFF" android:checked="true" />
            <RadioButton android:id="@+id/radioLayoutArc" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Arc"
                android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/radioLayout2x3" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="6 Slots (2×3)"
                android:textColor="#FFFFFF" />
        </RadioGroup>

        <TextView android:id="@+id/tvLayout2x3Warning"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚠ 6 values while driving — use sparingly"
            android:textColor="#FF9800" android:textSize="12sp"
            android:layout_marginBottom="16dp" android:visibility="gone" />

        <!-- Slot spinners — labels updated dynamically -->
        <LinearLayout android:id="@+id/sectionSlots"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="8dp">

            <!-- Slot 0 -->
            <LinearLayout android:id="@+id/layoutSlot0"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvSlot0" android:layout_width="100dp"
                        android:layout_height="wrap_content" android:text="Slot 1"
                        android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spinnerSlot0" android:layout_width="0dp"
                        android:layout_height="48dp" android:layout_weight="1"
                        android:backgroundTint="#FFFFFF" />
                </LinearLayout>
                <LinearLayout android:id="@+id/displayTypeRow0"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="100dp" android:paddingTop="4dp" android:visibility="gone">
                    <Button android:id="@+id/btnDisplayN0" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="N"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayArc0" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Arc"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayBar0" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Bar"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="8dp" />
                    <EditText android:id="@+id/etMin0" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Min"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp" android:layout_marginEnd="4dp"
                        android:visibility="gone" />
                    <EditText android:id="@+id/etMax0" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Max"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Slot 1 -->
            <LinearLayout android:id="@+id/layoutSlot1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvSlot1" android:layout_width="100dp"
                        android:layout_height="wrap_content" android:text="Slot 2"
                        android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spinnerSlot1" android:layout_width="0dp"
                        android:layout_height="48dp" android:layout_weight="1"
                        android:backgroundTint="#FFFFFF" />
                </LinearLayout>
                <LinearLayout android:id="@+id/displayTypeRow1"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="100dp" android:paddingTop="4dp" android:visibility="gone">
                    <Button android:id="@+id/btnDisplayN1" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="N"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayArc1" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Arc"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayBar1" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Bar"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="8dp" />
                    <EditText android:id="@+id/etMin1" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Min"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp" android:layout_marginEnd="4dp"
                        android:visibility="gone" />
                    <EditText android:id="@+id/etMax1" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Max"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Slot 2 -->
            <LinearLayout android:id="@+id/layoutSlot2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvSlot2" android:layout_width="100dp"
                        android:layout_height="wrap_content" android:text="Slot 3"
                        android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spinnerSlot2" android:layout_width="0dp"
                        android:layout_height="48dp" android:layout_weight="1"
                        android:backgroundTint="#FFFFFF" />
                </LinearLayout>
                <LinearLayout android:id="@+id/displayTypeRow2"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="100dp" android:paddingTop="4dp" android:visibility="gone">
                    <Button android:id="@+id/btnDisplayN2" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="N"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayArc2" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Arc"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayBar2" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Bar"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="8dp" />
                    <EditText android:id="@+id/etMin2" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Min"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp" android:layout_marginEnd="4dp"
                        android:visibility="gone" />
                    <EditText android:id="@+id/etMax2" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Max"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Slot 3 -->
            <LinearLayout android:id="@+id/layoutSlot3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvSlot3" android:layout_width="100dp"
                        android:layout_height="wrap_content" android:text="Slot 4"
                        android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spinnerSlot3" android:layout_width="0dp"
                        android:layout_height="48dp" android:layout_weight="1"
                        android:backgroundTint="#FFFFFF" />
                </LinearLayout>
                <LinearLayout android:id="@+id/displayTypeRow3"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="100dp" android:paddingTop="4dp" android:visibility="gone">
                    <Button android:id="@+id/btnDisplayN3" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="N"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayArc3" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Arc"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayBar3" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Bar"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="8dp" />
                    <EditText android:id="@+id/etMin3" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Min"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp" android:layout_marginEnd="4dp"
                        android:visibility="gone" />
                    <EditText android:id="@+id/etMax3" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Max"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Slots 4 & 5 — only visible in 2x3 layout -->
            <LinearLayout android:id="@+id/layoutSlot4" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvSlot4" android:layout_width="100dp"
                        android:layout_height="wrap_content" android:text="Slot 5"
                        android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spinnerSlot4" android:layout_width="0dp"
                        android:layout_height="48dp" android:layout_weight="1"
                        android:backgroundTint="#FFFFFF" />
                </LinearLayout>
                <LinearLayout android:id="@+id/displayTypeRow4"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="100dp" android:paddingTop="4dp" android:visibility="gone">
                    <Button android:id="@+id/btnDisplayN4" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="N"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayArc4" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Arc"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayBar4" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Bar"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="8dp" />
                    <EditText android:id="@+id/etMin4" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Min"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp" android:layout_marginEnd="4dp"
                        android:visibility="gone" />
                    <EditText android:id="@+id/etMax4" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Max"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/layoutSlot5" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvSlot5" android:layout_width="100dp"
                        android:layout_height="wrap_content" android:text="Slot 6"
                        android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spinnerSlot5" android:layout_width="0dp"
                        android:layout_height="48dp" android:layout_weight="1"
                        android:backgroundTint="#FFFFFF" />
                </LinearLayout>
                <LinearLayout android:id="@+id/displayTypeRow5"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="100dp" android:paddingTop="4dp" android:visibility="gone">
                    <Button android:id="@+id/btnDisplayN5" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="N"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayArc5" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Arc"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="4dp" />
                    <Button android:id="@+id/btnDisplayBar5" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="Bar"
                        android:backgroundTint="#444444" android:textColor="#FFFFFF"
                        android:textSize="12sp" android:layout_marginEnd="8dp" />
                    <EditText android:id="@+id/etMin5" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Min"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp" android:layout_marginEnd="4dp"
                        android:visibility="gone" />
                    <EditText android:id="@+id/etMax5" android:layout_width="64dp"
                        android:layout_height="36dp" android:hint="Max"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#FFFFFF" android:textColorHint="#666666"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Button android:id="@+id/btnResetLayout"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Reset to Defaults"
            android:backgroundTint="#444444" android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btnSavedVehicles"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Saved Vehicles →"
            android:backgroundTint="#1E1E1E" android:textColor="#00E676"
            android:layout_marginBottom="24dp" />

        <!-- ── AutoVakt Bridge ────────────────────────────────────────────────── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AutoVakt Bridge"
            android:textColor="#B0BEC5"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="24dp">

            <!-- Enable toggle -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBridgeEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bridge enabled"
                android:textColor="#FFFFFF"
                android:checked="true"
                android:layout_marginBottom="12dp" />

            <!-- Status line -->
            <TextView
                android:id="@+id/tvBridgeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting for connection"
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <!-- Address row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvBridgeAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0.0.0.0:35000"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btnBridgeCopy"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Copy"
                    android:textSize="12sp"
                    android:backgroundTint="#444444"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Instructions accordion -->
            <TextView
                android:id="@+id/tvBridgeInstructionsTrigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Setup instructions ▼"
                android:textColor="#00E676"
                android:textSize="13sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/layoutBridgeInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#2A2A2A"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="In ABRP: Settings → OBD Connection → WiFi ELM327 → enter the address above."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="In Car Scanner: add a WiFi ELM327 connection with the address above."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Advanced (port) accordion -->
            <TextView
                android:id="@+id/tvBridgeAdvancedTrigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Advanced ▼"
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/layoutBridgeAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#2A2A2A"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Port (default 35000)"
                    android:textColor="#B0BEC5"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etBridgePort"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="number"
                    android:text="35000"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#555555" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── Display Theme ───────────────────────────────────────────────── -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display Theme"
            android:textColor="#B0BEC5"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/radioGroupTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/radioThemeDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="16dp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioThemeLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="16dp" />

            <RadioButton
                android:id="@+id/radioThemeAuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="#FFFFFF" />
        </RadioGroup>

        <!-- Auto sub-section (visible only when Auto selected) -->
        <LinearLayout
            android:id="@+id/sectionAutoTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto mode"
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/radioGroupAutoMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioAutoTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time of Day"
                    android:textColor="#FFFFFF"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/radioAutoSensor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ambient Light Sensor"
                    android:textColor="#FFFFFF" />

                <RadioButton
                    android:id="@+id/radioAutoBest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best (Location + Sensor)"
                    android:textColor="#FFFFFF" />
            </RadioGroup>
        </LinearLayout>

        <!-- Time section (visible when Time or Best selected) -->
        <LinearLayout
            android:id="@+id/sectionTimeTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day Hours"
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvDawnTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="6:00 AM"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvDuskTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="8:00 PM"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:gravity="end" />
            </LinearLayout>

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/sliderDawnDusk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="24"
                android:stepSize="0.5"
                app:thumbRadius="12dp"
                app:trackColorActive="#00E676"
                app:trackColorInactive="#3A3A3A"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchUseLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use GPS for sunrise/sunset"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Sensor section (visible when Sensor or Best selected) -->
        <LinearLayout
            android:id="@+id/sectionSensorTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvLuxValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Switch to light above: 5000 lux"
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderLuxThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="500"
                android:valueTo="20000"
                android:stepSize="500"
                app:trackColorActive="#00E676"
                app:trackColorInactive="#3A3A3A" />
        </LinearLayout>

        <!-- ── ABRP Live Data ─────────────────────────────────────────────────── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABRP Live Data"
            android:textColor="#B0BEC5"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="24dp">

            <!-- Status -->
            <TextView
                android:id="@+id/tvAbrpStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not configured"
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <!-- Token input -->
            <EditText
                android:id="@+id/etAbrpToken"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Paste token from ABRP app"
                android:inputType="textNoSuggestions"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:backgroundTint="#555555"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get token: ABRP app -> Car Settings -> Live Data -> Generic -> Link"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <!-- Advanced (base URL) accordion -->
            <TextView
                android:id="@+id/tvAbrpAdvancedTrigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Advanced ▼"
                android:textColor="#B0BEC5"
                android:textSize="13sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/layoutAbrpAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#2A2A2A"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Server URL"
                    android:textColor="#B0BEC5"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etAbrpBaseUrl"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="https://api.iternio.com/1/tlm/send"
                    android:inputType="textNoSuggestions|textUri"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:backgroundTint="#555555" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── Screen Wake Lock ───────────────────────────────────────────────── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Keep Screen On"
            android:textColor="#B0BEC5" android:layout_marginBottom="12dp" />

        <RadioGroup android:id="@+id/radioGroupScreenWake"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="24dp">
            <RadioButton android:id="@+id/radioScreenOff"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="System default (screen times out)"
                android:textColor="#FFFFFF" android:checked="true" />
            <RadioButton android:id="@+id/radioScreenAlways"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Always on while app is open"
                android:textColor="#FFFFFF" />
            <RadioButton android:id="@+id/radioScreenCharging"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="On when charging / plugged in"
                android:textColor="#FFFFFF" />
        </RadioGroup>

        <!-- ── Diagnostics ────────────────────────────────────────────────────── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Diagnostics"
            android:textColor="#B0BEC5" android:layout_marginBottom="12dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1E1E1E"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="16dp" android:paddingBottom="16dp"
            android:layout_marginBottom="24dp">

            <TextView android:id="@+id/tvDiagAbrp"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="ABRP: not configured"
                android:textColor="#B0BEC5" android:textSize="13sp"
                android:fontFamily="monospace" android:layout_marginBottom="8dp" />

            <TextView android:id="@+id/tvDiagBridge"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Bridge: no clients"
                android:textColor="#B0BEC5" android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ──────────────────────────────────────────────────────────────── -->

        <Button
            android:id="@+id/btnImportProfile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Import Profile"
            android:backgroundTint="#FF9800"
            android:textColor="#000000"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnShareLogs"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Share Diagnostic Logs"
            android:backgroundTint="#424242"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Done"
            android:backgroundTint="#424242"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AutoVakt v--"
            android:textColor="#333333"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

    </LinearLayout>
</ScrollView>
